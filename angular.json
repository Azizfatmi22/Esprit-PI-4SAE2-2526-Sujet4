{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "formini-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": false
        },
        "@schematics/angular:directive": {
          "standalone": false
        },
        "@schematics/angular:pipe": {
          "standalone": false
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/formini-app",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.scss",
              "node_modules/leaflet/dist/leaflet.css"
            ],
            "scripts": [],
            "allowedCommonJsDependencies": [
              "stompjs",
              "sockjs-client"
            ],
            "server": "src/main.server.ts",
            "prerender": true,
            "ssr": {
              "entry": "server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
    "type": "anyComponentStyle",
    "maximumWarning": "100kb",
    "maximumError": "200kb"
  }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "formini-app:build:production"
            },
            "development": {
              "buildTarget": "formini-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
  "builder": "@angular-devkit/build-angular:karma",
  "options": {
    "codeCoverage": true,
    "polyfills": [
      "zone.js",
      "zone.js/testing"
    ],
    "tsConfig": "tsconfig.spec.json",
    "inlineStyleLanguage": "scss",
    "assets": [
      {
        "glob": "**/*",
        "input": "public"
      }
    ],
    "styles": [
      "src/styles.scss"
    ],
    "scripts": [
      "src/global-fix.js"
    ],
    "karmaConfig": "karma.conf.js",
    "include": [
      "src/app/front-office/reclamation/reclamation.component/reclamation.component.spec.ts",
      "src/app/back-office/admin-reclamations/admin-reclamations.component.spec.ts",
      "src/app/front-office/cart/cart.component.spec.ts",
      "src/app/front-office/payment/payment.component.spec.ts",
      "src/app/front-office/payment-success/payment-success.component.spec.ts",
      "src/app/front-office/RefundLearner/refund-learner/refund-learner.component.spec.ts",
      "src/app/front-office/installment/installment-payment/installment-payment.component.spec.ts",
      "src/app/front-office/installment/installment-success/installment-success.component.spec.ts",
      "src/app/back-office/admin-enrollments/admin-enrollments/admin-enrollments.component.spec.ts",
      "src/app/back-office/admin-installments/admin-installments/admin-installments.component.spec.ts"
    ]
  }
},
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/**/*.ts",
              "src/**/*.html"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "65b8f5ce-bd5f-448f-91a2-b2c80adb6ddb",
    "schematicCollections": [
      "angular-eslint"
    ]
  }
}